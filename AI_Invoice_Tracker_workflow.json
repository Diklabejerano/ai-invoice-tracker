    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst binaryKeys = Object.keys(item.binary);\n\nlet pdfKey = null;\nfor (const key of binaryKeys) {\n  if (item.binary[key].mimeType === 'application/pdf') {\n    pdfKey = key;\n    break;\n  }\n}\n\nif (pdfKey) {\n  return [{ json: item.json, binary: { data: item.binary[pdfKey] } }];\n} else {\n  return [{ json: { error: 'No PDF attachment found' } }];\n}"
      },
