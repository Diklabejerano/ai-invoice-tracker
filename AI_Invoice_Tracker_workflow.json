    {
      "parameters": {
        "jsCode": "const invoiceText = $input.first().json.text;\n\nconst requestBody = {\n  model: \"claude-sonnet-5\",\n  max_tokens: 2000,\n  messages: [\n    {\n      role: \"user\",\n      content: `You are an expert invoice data extractor. You handle invoices in any language including Hebrew.\n\nFIRST: Determine if this document is an actual invoice (חשבונית מס, חשבונית מס קבלה, חשבונית עסקה, tax invoice, invoice). If it is NOT an invoice (for example: account statement, receipt only, payment confirmation, bank statement, quote), return ONLY this JSON:\n{\"is_invoice\": false, \"document_type\": \"describe what it actually is\"}\n\nIf it IS an invoice, extract all data and return ONLY valid JSON with no additional text, no markdown, no backticks:\n{\"is_invoice\": true, \"vendor_name\": \"\", \"vendor_tax_id\": \"\", \"invoice_number\": \"\", \"invoice_date\": \"\", \"due_date\": \"\", \"currency\": \"\", \"line_items\": [{\"description\": \"\", \"quantity\": 0, \"unit_price\": 0, \"amount\": 0}], \"subtotal\": 0, \"tax_rate_percent\": 0, \"tax_total\": 0, \"total_amount\": 0, \"customer_name\": \"\", \"customer_email\": \"\", \"confidence\": {\"overall\": \"high/medium/low\", \"flags\": [\"list any uncertain fields\"]}}\n\nIf a field is not found use null.\n\nDOCUMENT TEXT:\n${invoiceText}`\n    }\n  ]\n};\n\nreturn [{ json: { body: requestBody } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        0
      ],
      "id": "899eea91-e6dd-4e68-b53b-bd3accb09d3f",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// Case 1: error object present → shouldn't happen if If node worked, but log if it does\nif (item.error) {\n  return [{ json: { skipped: true, reason: \"Error object leaked to parser\", raw: item } }];\n}\n\n// Case 2: response missing content field entirely\nif (!item.content) {\n  return [{ json: { skipped: true, reason: \"No content field in response\", raw: item } }];\n}\n\n// Case 3: response has content array — find the text block\nconst textBlock = item.content.find(c => c.type === \"text\");\n\nif (!textBlock) {\n  return [{ json: { skipped: true, reason: \"No text block in content array\", raw: item } }];\n}\n\nconst text = textBlock.text;\n\nlet d;\ntry {\n  d = JSON.parse(text);\n} catch (e) {\n  return [{ json: { skipped: true, reason: \"JSON parse failed\", text: text, raw: item } }];\n}\n\nif (!d.is_invoice) {\n  return [{ json: { skipped: true, reason: d.document_type } }];\n}\n\nreturn [{ json: {\n  vendor_name: d.vendor_name || \"\",\n  vendor_tax_id: d.vendor_tax_id || \"\",\n  invoice_number: d.invoice_number || \"\",\n  invoice_date: d.invoice_date || \"\",\n  currency: d.currency || \"\",\n  total_amount: d.total_amount || 0,\n  tax_total: d.tax_total || 0,\n  subtotal: d.subtotal || 0,\n  customer_name: d.customer_name || \"\",\n  customer_email: d.customer_email || \"\",\n  confidence: d.confidence ? d.confidence.overall : \"\",\n  processed_date: new Date().toISOString()\n}}];"
      },
